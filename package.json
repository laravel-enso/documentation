{
    "private": true,
    "engines": {
        "node": ">=20.9.0"
    },
    "scripts": {
        "dev": "vuepress dev docs",
        "build": "node scripts/netlify-build.mjs",
        "build:site": "yarn build:assets",
        "build:refresh": "yarn sync && yarn build:generator && yarn refresh:status && yarn build:assets",
        "scan": "node scripts/manage-sources.mjs scan",
        "sync": "node scripts/sync-readmes.mjs sync",
        "refresh:status": "node scripts/sync-readmes.mjs refresh-status",
        "cleanup:tracker": "node scripts/close-stale-tracker.mjs",
        "add:repo": "node scripts/manage-sources.mjs add-package",
        "remove:repo": "node scripts/manage-sources.mjs remove-package",
        "build:generator": "node scripts/sync-readmes.mjs generate",
        "build:assets": "vuepress build docs",
        "clean": "rm -rf docs/.vuepress/.cache docs/.vuepress/.temp docs/.vuepress/dist"
    },
    "devDependencies": {
        "@vuepress/bundler-vite": "^2.0.0-rc.25",
        "@vuepress/plugin-remove-pwa": "^2.0.0-rc.25",
        "@vuepress/plugin-search": "2.0.0-rc.24",
        "@vuepress/theme-default": "^2.0.0-rc.25",
        "sass-embedded": "^1.99.0",
        "vuepress": "^2.0.0-rc.25"
    }
}
